def test_pressure_loss_from_pipe(pipe_diameter, pipe_length, friction_factor, fluid_velocity, expected_pressure_loss):
    assert pressure_loss_from_pipe("0.048692", "0.00", "0.018", "1.75", "0.000") == approx(0.001)
    assert pressure_loss_from_pipe("0.048692", "200.00", "0.000", "1.75", "0.000") == approx(0.001)
    assert pressure_loss_from_pipe("0.048692", "200.00", "0.018", "0.00", "0.000") == approx(0.001)
    assert pressure_loss_from_pipe("0.048692", "200.00", "0.018", "1.75", "-113.008") == approx(0.001)
    assert pressure_loss_from_pipe("0.048692", "200.00", "0.018", "1.65", "-100.462") == approx(0.001)
    assert pressure_loss_from_pipe("0.286870", "1000.00", "0.013", "1.65", "-61.576") == approx(0.001)
    assert pressure_loss_from_pipe("0.286870", "1800.75", "0.013", "1.65", "-110.884") == approx(0.001)

def test_pressure_loss_from_fittings(fluid_velocity, quantity_fittings, expected_pressure_loss):
